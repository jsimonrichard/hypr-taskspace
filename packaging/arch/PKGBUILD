# Maintainer: Your Name <you@example.com>
pkgname=hypr-taskspace
pkgver=0.1.0
pkgrel=1
pkgdesc="Task-centric Hyprland control plane with Waybar integration"
arch=('x86_64' 'aarch64')
url="https://github.com/jsimonrichard/hypr-taskspace"
license=('MIT')
depends=('hyprland' 'waybar')
makedepends=('cargo' 'rust')
source=()
options=(!strip !lto)

build() {
  local root="$startdir/../.."
  cd "$root"

  # makepkg CFLAGS/LDFLAGS (-flto=auto, --as-needed) break bundled libsqlite3-sys linking
  export CARGO_TARGET_DIR="$startdir/target"
  unset CFLAGS CXXFLAGS LDFLAGS RUSTFLAGS

  cargo build --release -p tsk-cli -p tsk-waybar
}

package() {
  local root="$startdir/../.."
  cd "$root"

  install -Dm755 "$startdir/target/release/tsk" "$pkgdir/usr/bin/tsk"
  install -Dm755 "$startdir/target/release/libtsk_waybar.so" \
    "$pkgdir/usr/share/tsk/lib/libtsk_waybar.so"

  bash "$root/packaging/arch/install-share.sh" "$pkgdir" "$root"
}
