{
  "custom/lae-task": {
    "return-type": "json",
    "exec": "~/.local/share/lae/bin/lae-waybar-json task",
    "interval": "once",
    "signal": 11,
    "on-click": "~/.local/share/lae/bin/lae-task-tui",
    "on-click-right": "lae taskspace default"
  },
  "custom/lae-workspace-1": {
    "return-type": "json",
    "exec": "~/.local/share/lae/bin/lae-waybar-json workspace 1",
    "interval": "once",
    "signal": 11,
    "on-click": "~/.local/share/lae/bin/lae workspace go 1",
    "tooltip": "Workspace 1"
  },
  "custom/lae-workspace-2": {
